# Copy to .env on the server: cp .env.production.example .env

# Required — generate a random string (32+ characters)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Data paths (inside Docker volume — leave as-is)
DATABASE_PATH=./data/piano-examiner.db
UPLOAD_DIR=./data/uploads

# AI evaluation
EVALUATION_MODE=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PYTHON_PATH=python3
